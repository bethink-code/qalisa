# ─── Qalisa environment template ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env (it is gitignored).

NODE_ENV=development

# ─── Datastores (match infra/docker-compose.yml) ─────────────────────────────
# Host ports are 55432/6380 to avoid colliding with other local Postgres/Redis instances.
DATABASE_URL=postgres://qalisa:qalisa_dev@localhost:55432/qalisa
REDIS_URL=redis://localhost:6380

# ─── Engine API ──────────────────────────────────────────────────────────────
ENGINE_PORT=4000
ENGINE_HOST=0.0.0.0

# ─── Credential vault ────────────────────────────────────────────────────────
# Master key for envelope encryption of tenant provider credentials.
# 32-byte key, base64-encoded. Generate with:  openssl rand -base64 32
# Self-hosted: this comes from env (this file / Doppler). KMS is a later swap.
VAULT_MASTER_KEY=
